# YouTube Data API v3 key — generate a fresh one at https://console.cloud.google.com/apis/credentials
# IMPORTANT: If this key was previously committed in git history, REVOKE it and generate a new one.
YOUTUBE_API_KEY=your_youtube_api_key_here

# MySQL connection — use docker-compose.yml defaults for local development
MYSQL_HOST=localhost
MYSQL_USER=yt_user
MYSQL_PASSWORD=yt_password
MYSQL_DATABASE=youtube_creator_retention
